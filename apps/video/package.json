{
  "name": "@knitly/video",
  "version": "0.1.0",
  "description": "Remotion marketing videos for slash.cash",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.477",
    "@remotion/tailwind-v4": "4.0.477",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.477",
    "tailwindcss": "4.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.477",
    "@types/react": "^18",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.7.3"
  },
  "scripts": {
    "dev": "remotion studio --port 3001",
    "build": "remotion bundle",
    "render": "remotion render src/index.ts SlashCashSocial out/slashcash-social.mp4",
    "render:story": "remotion render src/index.ts InboxToInsight out/inbox-to-insight.mp4",
    "render:viral:preview": "remotion render src/index.ts InboxToInsight out/inbox-viral-smoke.mp4 --frames=0-90",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "typecheck": "tsc --noEmit",
    "test": "pnpm lint"
  },
  "sideEffects": [
    "*.css"
  ]
}
