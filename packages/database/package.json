{
  "name": "@workspace/database",
  "version": "0.1.3",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch ",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "lint": "echo 'Linting not configured for database package'",
    "lint:fix": "echo 'Linting not configured for database package'",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "check": "drizzle-kit check",
    "pull": "drizzle-kit pull",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/better-sqlite3": "latest",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.30.6",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.40.1"
  }
}
