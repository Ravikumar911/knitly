{
  "name": "@workspace/tasks",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "lint": "echo 'Linting not configured for tasks package'",
    "lint:fix": "echo 'Linting not configured for tasks package'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts",
    "manual:order-extract": "tsx scripts/manual-order-extract.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./trigger/*": {
      "types": "./src/trigger/*.ts",
      "import": "./dist/trigger/*.js",
      "default": "./dist/trigger/*.js"
    },
    "./ai/*": {
      "types": "./src/ai/*.ts",
      "import": "./dist/ai/*.js",
      "default": "./dist/ai/*.js"
    },
    "./agents/*": {
      "types": "./src/agents/*.ts",
      "import": "./dist/agents/*.js",
      "default": "./dist/agents/*.js"
    },
    "./extract/*": {
      "types": "./src/extract/*.ts",
      "import": "./dist/extract/*.js",
      "default": "./dist/extract/*.js"
    },
    "./gmail/*": {
      "types": "./src/gmail/*.ts",
      "import": "./dist/gmail/*.js",
      "default": "./dist/gmail/*.js"
    },
    "./merchants/*": {
      "types": "./src/merchants/*.ts",
      "import": "./dist/merchants/*.js",
      "default": "./dist/merchants/*.js"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "import": "./dist/types/*.js",
      "default": "./dist/types/*.js"
    },
    "./runtime/*": {
      "types": "./src/runtime/*.ts",
      "import": "./dist/runtime/*.js",
      "default": "./dist/runtime/*.js"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "import": "./dist/utils/*.js",
      "default": "./dist/utils/*.js"
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "1.0.17",
    "ai": "5.0.26",
    "@workspace/database": "workspace:*",
    "imapflow": "^1.0.181",
    "mailparser": "^3.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*"
  }
}
