{
  "name": "@workspace/evals",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "eval": "tsx src/hello.eval.ts",
    "eval:ui": "braintrust eval src/hello.eval.ts",
    "eval:swiggy": "tsx src/swiggy-extraction.eval.ts",
    "eval:swiggy:nano": "MODEL_NAME=gpt-5-nano tsx src/swiggy-extraction.eval.ts",
    "eval:swiggy:mini": "MODEL_NAME=gpt-5-mini tsx src/swiggy-extraction.eval.ts",
    "eval:swiggy:4o": "MODEL_NAME=gpt-4o tsx src/swiggy-extraction.eval.ts",
    "eval:swiggy:ui": "braintrust eval src/swiggy-extraction.eval.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.32",
    "@workspace/tasks": "workspace:*",
    "ai": "5.0.26",
    "autoevals": "^0.0.94",
    "braintrust": "^0.0.165",
    "dotenv": "^16.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "tsx": "^4.19.3",
    "typescript": "5.7.3"
  }
}
