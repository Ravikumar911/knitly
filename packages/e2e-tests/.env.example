# Google Test Account Credentials
# Copy this file to .env and fill in your test Google account credentials
GOOGLE_TEST_EMAIL=your-test-email@gmail.com
GOOGLE_TEST_PASSWORD=your-test-password

# Supabase Configuration (usually set in root .env)
# These are optional here if you want to override root values
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
