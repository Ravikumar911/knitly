{
  "name": "@workspace/e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test --project=chromium --project=firefox --project=webkit",
    "architecture-smells": "tsx architecture-smells.test.ts",
    "fixtures:check": "tsx scripts/fixtures-check.ts",
    "bench": "tsx bench/perf-budget.ts",
    "e2e:phase-1": "tsx scenarios/phase-1.ts",
    "e2e:phase-2": "tsx scenarios/phase-2.ts",
    "e2e:phase-3": "tsx scenarios/phase-3.ts",
    "e2e:phase-4": "tsx scenarios/phase-4.ts",
    "e2e:phase-5": "tsx scenarios/phase-5.ts",
    "e2e:all": "pnpm e2e:phase-1 && pnpm e2e:phase-2 && pnpm e2e:phase-3 && pnpm e2e:phase-4 && pnpm e2e:phase-5",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed --project=chromium --project=firefox --project=webkit",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3"
  }
}
