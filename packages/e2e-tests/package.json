{
  "name": "@workspace/e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:journeys": "playwright test",
    "architecture-smells": "tsx architecture-smells.test.ts",
    "fixtures:check": "tsx scripts/fixtures-check.ts",
    "bench": "tsx bench/perf-budget.ts && tsx bench/sync-1y.ts",
    "e2e:onboarding": "tsx scenarios/onboarding-fast-path.ts",
    "e2e:all": "pnpm test && pnpm e2e:onboarding",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed --project=chromium --project=firefox --project=webkit",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/tasks": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "better-sqlite3": "latest",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3"
  }
}
