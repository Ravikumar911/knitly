{
  "name": "@workspace/e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:journeys": "playwright test",
    "architecture-smells": "tsx architecture-smells.test.ts",
    "fixtures:check": "tsx scripts/fixtures-check.ts",
    "bench": "tsx bench/perf-budget.ts && tsx bench/sync-1y.ts",
    "journey:boot-local-app": "tsx scenarios/phase-1.ts",
    "journey:sync-inbox-and-receipts": "tsx scenarios/phase-2.ts",
    "journey:onboard-recovery": "tsx scenarios/phase-3.ts",
    "journey:quality-gates": "tsx scenarios/phase-4.ts",
    "journey:release-readiness": "tsx scenarios/phase-5.ts",
    "e2e:ingest": "tsx scenarios/phase-2.ts",
    "e2e:onboarding": "tsx scenarios/onboarding-fast-path.ts",
    "e2e:cli": "tsx scenarios/phase-3.ts",
    "e2e:pyramid": "tsx scenarios/phase-4.ts",
    "e2e:release": "tsx scenarios/phase-5.ts",
    "e2e:all": "pnpm e2e:ingest && pnpm e2e:cli && pnpm e2e:pyramid && pnpm e2e:release && pnpm e2e:onboarding",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed --project=chromium --project=firefox --project=webkit",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3"
  }
}
