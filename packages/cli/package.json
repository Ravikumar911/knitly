{
  "name": "slashcash",
  "version": "0.1.10",
  "private": false,
  "description": "Local-first personal finance dashboard CLI for slash.cash.",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ravikumar911/knitly.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Ravikumar911/knitly/issues"
  },
  "homepage": "https://github.com/Ravikumar911/knitly#readme",
  "keywords": [
    "finance",
    "personal-finance",
    "sqlite",
    "local-first",
    "cli"
  ],
  "type": "module",
  "bin": {
    "slashcash": "bin/slashcash.mjs"
  },
  "files": [
    "bin",
    "dist",
    "dist/app/apps/main/.next",
    "bundled-skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "bundle:app": "node scripts/bundle-app.mjs",
    "bundle:check": "node scripts/verify-bundle.mjs",
    "bundle:pack-smoke": "node scripts/verify-packed-install.mjs",
    "dev": "node scripts/run-dev.mjs",
    "lint": "echo 'Linting not configured for cli package'",
    "lint:fix": "echo 'Linting not configured for cli package'",
    "release:check": "node scripts/release-check.mjs",
    "release:verify-published": "node scripts/verify-published-install.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@ai-sdk/openai-compatible": "2.0.41",
    "ai": "6.0.168",
    "better-sqlite3": "latest",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "imapflow": "^1.0.181",
    "keytar": "^7.9.0",
    "mailparser": "^3.7.2",
    "next": "15.5.9",
    "node-cron": "^3.0.3",
    "picocolors": "^1.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/database": "workspace:*",
    "@workspace/tasks": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "tsx": "^4.19.3",
    "typescript": "5.7.3"
  }
}
