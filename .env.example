# slash.cash local runtime

# Local app data directory. Defaults to ~/.slashcash.
# SLASHCASH_HOME=/Users/you/.slashcash

# SQLite database file. Defaults to $SLASHCASH_HOME/db.sqlite.
# SQLITE_DB_PATH=/Users/you/.slashcash/db.sqlite

# Dashboard port. Defaults to 3000.
# SLASHCASH_PORT=3000

# Ollama-compatible local AI endpoint.
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_CHAT_MODEL=gemma4:latest

# Set to 1 when running checks without a local model server.
# SLASHCASH_DOCTOR_SKIP_OLLAMA=1
