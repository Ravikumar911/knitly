{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "SLASHCASH_ASSISTANT_PROVIDER",
    "SLASHCASH_ASSISTANT_BASE_URL",
    "SLASHCASH_ASSISTANT_CHAT_MODEL",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "SLASHCASH_HOME",
        "SQLITE_DB_PATH",
        "SLASHCASH_ASSISTANT_PROVIDER",
        "SLASHCASH_ASSISTANT_BASE_URL",
        "SLASHCASH_ASSISTANT_CHAT_MODEL",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "SLASHCASH_PORT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "SLASHCASH_ASSISTANT_PROVIDER",
        "SLASHCASH_ASSISTANT_BASE_URL",
        "SLASHCASH_ASSISTANT_CHAT_MODEL",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "SLASHCASH_EVAL_SKIP_MODEL",
        "SLASHCASH_EVAL_THRESHOLD",
        "SLASHCASH_BUNDLE_BUDGET_BYTES",
        "SLASHCASH_BENCH_VERSION_MS",
        "SLASHCASH_BENCH_DOCTOR_QUICK_MS"
      ]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "cache": false
    },
    "eval": {
      "cache": false,
      "env": ["SLASHCASH_EVAL_SKIP_MODEL", "SLASHCASH_EVAL_THRESHOLD"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_*"]
    }
  }
}
