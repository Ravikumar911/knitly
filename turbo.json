{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "TRIGGER_SECRET_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NODE_ENV",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_VERCEL_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["e2e/**/*", "playwright.config.ts"],
      "outputs": ["test-results/**", "playwright-report/**"],
      "cache": false
    },
    "test:e2e:ui": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test:e2e:headed": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:e2e:debug": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
