{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "TRIGGER_SECRET_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NODE_ENV",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_VERCEL_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["MODEL_NAME"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "eval": {
      "cache": false,
      "env": [
        "OPENAI_API_KEY",
        "BRAINTRUST_API_KEY",
        "MODEL_NAME"
      ]
    },
    "eval:swiggy": {
      "cache": false,
      "env": [
        "OPENAI_API_KEY",
        "BRAINTRUST_API_KEY",
        "MODEL_NAME"
      ]
    },
    "eval:swiggy:nano": {
      "cache": false,
      "env": [
        "OPENAI_API_KEY",
        "BRAINTRUST_API_KEY",
        "MODEL_NAME"
      ]
    },
    "eval:swiggy:mini": {
      "cache": false,
      "env": [
        "OPENAI_API_KEY",
        "BRAINTRUST_API_KEY",
        "MODEL_NAME"
      ]
    },
    "eval:swiggy:ui": {
      "cache": false,
      "env": [
        "OPENAI_API_KEY",
        "BRAINTRUST_API_KEY",
        "MODEL_NAME"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
