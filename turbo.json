{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "SLASHCASH_HOME",
        "SQLITE_DB_PATH",
        "OLLAMA_BASE_URL",
        "OLLAMA_CHAT_MODEL",
        "SLASHCASH_PORT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["OLLAMA_BASE_URL", "OLLAMA_CHAT_MODEL"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "eval": {
      "cache": false,
      "env": [
        "OLLAMA_BASE_URL",
        "OLLAMA_CHAT_MODEL"
      ]
    },
    "eval:swiggy": {
      "cache": false,
      "env": [
        "OLLAMA_BASE_URL",
        "OLLAMA_CHAT_MODEL"
      ]
    },
    "eval:swiggy:nano": {
      "cache": false,
      "env": [
        "OLLAMA_BASE_URL",
        "OLLAMA_CHAT_MODEL"
      ]
    },
    "eval:swiggy:mini": {
      "cache": false,
      "env": [
        "OLLAMA_BASE_URL",
        "OLLAMA_CHAT_MODEL"
      ]
    },
    "eval:swiggy:ui": {
      "cache": false,
      "env": [
        "OLLAMA_BASE_URL",
        "OLLAMA_CHAT_MODEL"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_*"]
    }
  }
}
