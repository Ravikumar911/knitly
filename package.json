{
  "name": "slash-cash",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test --filter=@workspace/e2e-tests",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:status": "changeset status",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo build && changeset publish"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.17",
    "@ai-sdk/mistral": "2.0.24",
    "@ai-sdk/openai": "^2.0.32",
    "@ai-sdk/react": "2.0.26",
    "@hookform/resolvers": "^4.1.3",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "@tanstack/react-query": "^5.71.1",
    "@trigger.dev/sdk": "latest",
    "@trpc/client": "^11.0.1",
    "@trpc/server": "^11.0.1",
    "@trpc/tanstack-react-query": "^11.0.2",
    "@vercel/analytics": "1.5.0",
    "ai": "5.0.26",
    "client-only": "^0.0.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "lucide-react": "^0.475.0",
    "next": "15.2.8",
    "next-themes": "^0.4.4",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.11.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@trigger.dev/build": "latest",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "autoprefixer": "^10.0.1",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.20.1",
    "prettier": "^3.5.1",
    "tsx": "^4.19.3",
    "turbo": "^2.4.2",
    "typescript": "5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "description": "A modern, type-safe, and scalable monorepo built with Next.js, Supabase, shadcn/ui, Drizzle ORM, tRPC, and TriggerDev. Features strict separation of concerns and centralized database management.",
  "main": "eslint.config.mjs",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
