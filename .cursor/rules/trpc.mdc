#### ✅ Client Component Usage Patterns
```typescript
// ✅ useSuspenseQuery with queryOptions pattern
'use client';
import { useSuspenseQuery } from '@tanstack/react-query';
import { useTRPC } from '@/trpc/client';

export function TransactionTable() {
  const trpc = useTRPC();
  
  // ✅ Use queryOptions for consistency with server prefetching
  const queryOptions = useMemo(() => {
    return trpc.transactions.list.queryOptions({
      page,
      pageSize,
      filters: { sortBy: 'date', sortOrder: sortDirection },
    });
  }, [trpc.transactions.list, page, pageSize, sortDirection]);

  const { data } = useSuspenseQuery(queryOptions);
  
  return (
    <div>
      {data.transactions.map(transaction => (
        <div key={transaction.id}>{transaction.merchantName}</div>
      ))}
    </div>
  );
}
```

#### ✅ Mutations with Error Handling
```typescript
// ✅ Mutation pattern with proper error handling
import { useMutation } from '@tanstack/react-query';
import { TRPCClientError } from '@trpc/client';

export function SyncButton() {
  const trpc = useTRPC();
  
  const syncMutation = useMutation(trpc.emails.initiateSync.mutationOptions({
    onSuccess: () => {
      // Handle success
      console.log('Sync started successfully');
    },
    onError: (err) => {
      if (err instanceof TRPCClientError) {
        setError(err.message || "Failed to start sync");
      } else {
        setError("An error occurred");
      }
    }
  }));

  return (
    <button onClick={() => syncMutation.mutate()}>
      {syncMutation.isPending ? 'Starting...' : 'Start Sync'}
    </button>
  );
}
```

#### ✅ Conditional Polling Pattern
```typescript
// ✅ Smart polling with conditional refetch
const { data: progressData } = useQuery({
  ...trpc.emails.getSyncProgress.queryOptions(),
  refetchInterval: (query) => {
    const data = query.state.data;
    const syncStatus = data?.syncStatus;
    
    const activeSyncStates = ['counting_emails', 'in_progress', 'syncing'];
    const shouldPoll = syncTriggered && syncStatus && activeSyncStates.includes(syncStatus);
    
    return shouldPoll ? 1000 : false;
  },
  enabled: syncTriggered,
  staleTime: 0,
});
```

### ⚙️ Query Client Configuration

#### ✅ Optimized Query Client ([query-client.ts](mdc:apps/main/trpc/query-client.ts))
```typescript
// query-client.ts
import { defaultShouldDehydrateQuery, QueryClient } from '@tanstack/react-query';
import superjson from 'superjson';

export function makeQueryClient() {
  return new QueryClient({
    defaultOptions: {
      queries: {
        staleTime: 30 * 1000, // 30 seconds
      },
      dehydrate: {
        // serializeData: superjson.serialize, // Enable if using complex types
        shouldDehydrateQuery: (query) =>
          defaultShouldDehydrateQuery(query) ||
          query.state.status === 'pending',
      },
      hydrate: {
        // deserializeData: superjson.deserialize,
      },
    },
  });
}
```

