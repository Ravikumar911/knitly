#### ✅ Type Safety with Database
```typescript
// ✅ Use proper TypeScript types from database package
export const transactionsRouter = createTRPCRouter({
  list: protectedProcedure
    .input(z.object({
      filters: transactionFiltersSchema.optional(),
    }))
    .query(async ({ input, ctx }) => {
      // ✅ Type-safe database query
      const transactions = await getTransactionsWithEmails(
        ctx.userId!,
        input.filters as TransactionFilters, // ✅ Proper type casting
        pageSize,
        offset
      );
      
      return transactions;
    }),
});
