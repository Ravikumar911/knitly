#### ⚠️ Deprecated Pattern (AI SDK 4.x - DO NOT USE)
```typescript
// ❌ DEPRECATED: ai/react is removed in AI SDK 5.0
// This pattern is for reference only - do not use in new code
'use client';
import { useChat } from 'ai/react'; // ❌ This import path is deprecated

export function OldChatInterface() {
  // ❌ Old API with message.content and handleSubmit
  const { messages, input, handleInputChange, handleSubmit, isLoading } = useChat({
    api: '/api/chat',
  });

  return (
    <div className="flex flex-col gap-4">
      <div className="flex-1 space-y-4">
        {messages.map((message) => (
          <div key={message.id}>
            {/* ❌ message.content no longer exists in v5 */}
            <strong>{message.role}:</strong> {message.content}
          </div>
        ))}
      </div>
      
      <form onSubmit={handleSubmit}>
        {/* ❌ handleInputChange and handleSubmit are deprecated */}
        <input value={input} onChange={handleInputChange} />
        <button type="submit">Send</button>
      </form>
    </div>
  );
}
```

#### 📋 AI SDK 4.x vs 5.0 Comparison

| Feature | AI SDK 4.x (Deprecated) | AI SDK 5.0 (Current) |
|---------|------------------------|----------------------|
| **Package** | `ai/react` ❌ | `@ai-sdk/react` ✅ |
| **Import** | `import { useChat } from 'ai/react'` | `import { useChat } from '@ai-sdk/react'` |
| **Message Structure** | `message.content` (string) | `message.parts[]` (array of parts) |
| **Message Type** | `Message` | `UIMessage` |
| **Input Handling** | `handleInputChange` + `input` | Manual `useState` + `setInput` |
| **Submission** | `handleSubmit` (form handler) | `sendMessage({ text })` |
| **Initial Messages** | `initialMessages` prop | `messages` prop |
| **Tool Control** | `maxSteps` parameter | `sendAutomaticallyWhen` + `onToolCall` |
| **Status** | ❌ Removed in v5 | ✅ Current standard |

#### 🎯 Key Changes in AI SDK 5.0

1. **New Message Structure with Parts**
   ```typescript
   // v5 message structure
   interface UIMessage {
     id: string;
     role: 'user' | 'assistant' | 'system';
     parts: Array<
       | { type: 'text'; text: string }
       | { type: 'tool-call'; toolName: string; toolCallId: string; args: unknown }
       | { type: 'tool-result'; toolName: string; toolCallId: string; result: unknown }
     >;
     createdAt?: Date;
   }
   ```

2. **New Tool Execution Control**
   ```typescript
   const { messages, sendMessage, addToolResult } = useChat({
     // Automatically send when tool calls are complete
     sendAutomaticallyWhen: lastAssistantMessageIsCompleteWithToolCalls,
     
     // Handle tool calls
     async onToolCall({ toolCall }) {
       const result = await executeToolCall(toolCall);
       addToolResult({
         tool: toolCall.toolName,
         toolCallId: toolCall.toolCallId,
         output: result,
       });
       // Don't await addToolResult when using sendAutomaticallyWhen
     },
   });
   ```

3. **Shared Chat Instances**
   ```typescript
   // Share chat state across components
   const { chat } = useSharedChat();
   
   // Component A
   const { messages, sendMessage } = useChat({ chat });
   
   // Component B (shares same chat)
   const { messages } = useChat({ chat });
   ```

#### ✅ When to Use AI SDK 5.0
- ✅ **All new projects** - Always use `@ai-sdk/react` with v5 API
- ✅ **Tool calls and multi-step agents** - v5 provides better control
- ✅ **Complex message rendering** - Parts-based structure is more flexible
- ✅ **Type safety** - Fully typed messages and tool calls

## Advanced Patterns

### Structured Object Streaming (AI SDK 5.0)
```typescript
'use client';
import { useObject } from '@ai-sdk/react';
import { z } from 'zod';

const schema = z.object({
  recipe: z.object({
    name: z.string(),
    ingredients: z.array(z.string()),
    steps: z.array(z.string()),
  }),
});

export function RecipeGenerator() {
  const { object, submit, isLoading } = useObject({
    api: '/api/generate-recipe',
    schema,
  });

  return (
    <div>
      <button onClick={() => submit('Generate a pasta recipe')} disabled={isLoading}>
        {isLoading ? 'Generating...' : 'Generate Recipe'}
      </button>
      
      {object && (
        <div>
          <h2>{object.recipe?.name}</h2>
          <h3>Ingredients:</h3>
          <ul>
            {object.recipe?.ingredients?.map((ingredient, i) => (
              <li key={i}>{ingredient}</li>
            ))}
          </ul>
          <h3>Steps:</h3>
          <ol>
            {object.recipe?.steps?.map((step, i) => (
              <li key={i}>{step}</li>
            ))}
          </ol>
        </div>
      )}
    </div>
  );
}
```

### Multi-Modal Chat (AI SDK 5.0)
```typescript
'use client';
import { useChat } from '@ai-sdk/react';
import { useState } from 'react';

export function MultiModalChat() {
  const [input, setInput] = useState('');
  const [files, setFiles] = useState<FileList | undefined>(undefined);
  const { messages, sendMessage, isLoading } = useChat();

  return (
    <div className="flex flex-col gap-4">
      {/* Render messages with parts */}
      <div className="flex-1 space-y-4">
        {messages.map(message => (
          <div key={message.id}>
            {message.parts.map((part, i) => {
              if (part.type === 'text') {
                return <div key={i}>{part.text}</div>;
              }
              if (part.type === 'image') {
                return <img key={i} src={part.image} alt="uploaded" />;
              }
            })}
          </div>
        ))}
      </div>

      {/* Input form */}
      <form onSubmit={(e) => {
        e.preventDefault();
        const content = [];
        
        // Add text content
        if (input) {
          content.push({ type: 'text' as const, text: input });
        }
        
        // Add image content
        if (files) {
          Array.from(files).forEach(file => {
            const reader = new FileReader();
            reader.onload = () => {
              content.push({
                type: 'image' as const,
                image: reader.result as string,
              });
            };
            reader.readAsDataURL(file);
          });
        }
        
        sendMessage({ content });
        setInput('');
        setFiles(undefined);
      }}>
        <input
          type="file"
          onChange={(e) => setFiles(e.target.files ?? undefined)}
          multiple
          accept="image/*"
        />
        <input
          value={input}
          onChange={(e) => setInput(e.target.value)}
          placeholder="Describe the images..."
        />
        <button type="submit" disabled={isLoading}>
          {isLoading ? 'Sending...' : 'Send'}
        </button>
      </form>
    </div>
  );
}
```

### Agent with Tools
```typescript
// app/api/agent/route.ts
import { streamText, tool } from 'ai';
import { openai } from '@ai-sdk/openai';
import { z } from 'zod';

export async function POST(req: Request) {
  const { messages } = await req.json();

  const result = await streamText({
    model: openai('gpt-4o'),
    messages,
    tools: {
      getWeather: tool({
        description: 'Get current weather for a location',
        inputSchema: z.object({  // ✅ Use inputSchema, not parameters
          location: z.string().describe('The city and state'),
        }),
        execute: async ({ location }) => {
          // Call weather API
          return { temperature: 72, condition: 'sunny' };
        },
      }),
      
      searchWeb: tool({
        description: 'Search the web for information',
        inputSchema: z.object({  // ✅ Use inputSchema, not parameters
          query: z.string().describe('Search query'),
        }),
        execute: async ({ query }) => {
          // Call search API
          return { results: ['Result 1', 'Result 2'] };
        },
      }),
    },
    maxToolRoundtrips: 5,
  });

  return result.toDataStreamResponse();
}
```

#### 🚨 Critical: Tool Function Contract

The `tool()` function from the AI SDK has a specific contract:

```typescript
import { tool } from 'ai';
import { z } from 'zod';

// ✅ CORRECT: Use inputSchema
export const weatherTool = tool({
  description: 'Get the weather in a location',
  inputSchema: z.object({
    location: z.string().describe('The location to get the weather for'),
  }),
  execute: async ({ location }) => ({
    location,
    temperature: 72 + Math.floor(Math.random() * 21) - 10,
  }),
});

// ❌ WRONG: Do not use 'parameters'
export const wrongTool = tool({
  description: 'This will cause TypeScript errors',
  parameters: z.object({ // ❌ This property doesn't exist
    location: z.string(),
  }),
  execute: async ({ location }) => { /* ... */ },
});
```

**Key Points:**
- ✅ Use `inputSchema` (not `parameters`)
- ✅ Let TypeScript infer the `execute` function's return type
- ✅ Ensure all code paths in `execute` return consistent types
- ❌ Don't add explicit return type annotations to `execute`

## Error Handling

### Client-Side Error Handling (AI SDK 5.0)
```typescript
'use client';
import { useChat } from '@ai-sdk/react';
import { useState } from 'react';

export function ChatWithErrorHandling() {
  const [input, setInput] = useState('');
  const { messages, sendMessage, error, isLoading } = useChat({
    onError: (error) => {
      console.error('Chat error:', error);
      // Handle error (show toast, etc.)
    },
  });

  if (error) {
    return (
      <div className="p-4 bg-red-100 border border-red-400 rounded">
        <p className="text-red-700">Error: {error.message}</p>
        <button onClick={() => window.location.reload()}>
          Retry
        </button>
      </div>
    );
  }

  return (
    <div className="flex flex-col gap-4">
      <div className="flex-1 space-y-4">
        {messages.map(message => (
          <div key={message.id}>
            {message.parts.map((part, i) => {
              if (part.type === 'text') {
                return <div key={i}>{part.text}</div>;
              }
            })}
          </div>
        ))}
      </div>
      
      <form onSubmit={e => {
        e.preventDefault();
        sendMessage({ text: input });
        setInput('');
      }}>
        <input
          value={input}
          onChange={e => setInput(e.target.value)}
          placeholder="Type your message..."
          disabled={isLoading}
        />
        <button type="submit" disabled={isLoading}>
          {isLoading ? 'Sending...' : 'Send'}
        </button>
      </form>
    </div>
  );
}
```

### Server-Side Error Handling
```typescript
// app/api/chat/route.ts
import { streamText } from 'ai';
import { openai } from '@ai-sdk/openai';

export async function POST(req: Request) {
  try {
    const { messages } = await req.json();

    const result = await streamText({
      model: openai('gpt-4o'),
      messages,
    });

    return result.toDataStreamResponse();
  } catch (error) {
    console.error('API error:', error);
    
    return new Response(
      JSON.stringify({ error: 'Internal server error' }),
      { 
        status: 500,
        headers: { 'Content-Type': 'application/json' }
      }
    );
  }
}
```

